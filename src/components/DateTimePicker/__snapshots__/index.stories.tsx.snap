              role="spinbutton"
              spellcheck="false"
              autocapitalize="none"
              autocorrect="off"
              inputmode="numeric"
              class="MuiPickersSectionList-sectionContent MuiPickersInputBase-sectionContent css-mui-classname"
        >
          mm
        </span>
        <span class="MuiPickersInputBase-sectionAfter css-mui-classname">
        </span>
      </span>
    </div>
    <div class="MuiInputAdornment-root MuiInputAdornment-positionEnd MuiInputAdornment-outlined MuiInputAdornment-sizeMedium css-mui-classname">
      <button class="MuiButtonBase-root MuiIconButton-root MuiIconButton-edgeEnd MuiIconButton-sizeMedium css-mui-classname"
              tabindex="0"
              type="button"
              aria-label="Choose time"
              data-mui-picker-open-button="true"
      >
        <svg class="MuiSvgIcon-root MuiSvgIcon-fontSizeMedium css-mui-classname"
             focusable="false"
             aria-hidden="true"
             viewbox="0 0 24 24"
        >
          <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z">
          </path>
          <path d="M12.5 7H11v6l5.25 3.15.75-1.23-4.5-2.67z">
          </path>
        </svg>
      </button>
    </div>
    <fieldset aria-hidden="true"
              class="MuiPickersOutlinedInput-notchedOutline css-mui-classname"
    >
      <legend class="css-mui-classname">
        <span class="css-mui-classname">
          Date Time
        </span>
      </legend>
    </fieldset>
    <input class="MuiPickersInputBase-input MuiPickersOutlinedInput-input css-mui-classname"
           id=":ru:"
           aria-hidden="true"
           tabindex="-1"
           value
    >
  </div>
</div>
`;
