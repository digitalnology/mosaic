        <span class="MuiPickersInputBase-sectionAfter css-mui-classname">
          :
        </span>
      </span>
      <span data-sectionindex="1"
            class="MuiPickersSectionList-section css-mui-classname"
      >
        <span class="MuiPickersInputBase-sectionBefore css-mui-classname">
        </span>
        <span aria-readonly="false"
              aria-valuemin="0"
              aria-valuemax="59"
              aria-valuetext="Empty"
              aria-label="Minutes"
